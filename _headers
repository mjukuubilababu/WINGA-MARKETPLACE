/*
  Cache-Control: public, max-age=31536000, immutable
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://winga-pflp.onrender.com https://*.onrender.com https://wingamarket.com; img-src 'self' data: https://winga-pflp.onrender.com https://*.onrender.com https://wingamarket.com; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; frame-src 'none'; object-src 'none'

/product/*
  Cache-Control: no-store, must-revalidate

/api/product/*
  Cache-Control: no-store, must-revalidate

/og-images/*
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: no-store, must-revalidate

/
  Cache-Control: no-store, must-revalidate
