{
  "cleanUrls": false,
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data: blob: https://winga-pflp.onrender.com https://wingamarket.com; font-src 'self' data:; media-src 'self' data: blob: https://winga-pflp.onrender.com; connect-src 'self' https://winga-pflp.onrender.com https://wingamarket.com https://cloudflareinsights.com https://static.cloudflareinsights.com; script-src 'self' https://static.cloudflareinsights.com; script-src-elem 'self' https://static.cloudflareinsights.com; script-src-attr 'none'; style-src 'self'; style-src-elem 'self' 'unsafe-inline'; style-src-attr 'unsafe-inline'; worker-src 'self'; manifest-src 'self'; frame-src 'none'; upgrade-insecure-requests"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(app|app-core|data-service|mock-data|winga-config|winga-modules)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/src/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/style.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [],
  "redirects": [
    {
      "source": "/__winga-image__",
      "destination": "https://winga-pflp.onrender.com/__winga-image__",
      "permanent": false
    },
    {
      "source": "/api/product/:id",
      "destination": "/product/:id",
      "permanent": false
    },
    {
      "source": "/winga",
      "destination": "/",
      "permanent": false
    }
  ]
}
