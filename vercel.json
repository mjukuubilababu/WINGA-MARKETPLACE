{
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(app|app-core|data-service|mock-data|winga-config)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/src/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/style.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/__winga-image__",
      "has": [
        {
          "type": "query",
          "key": "u",
          "value": "(?<u>.*)"
        }
      ],
      "destination": "https://winga-pflp.onrender.com/__winga-image__?u=:u"
    },
    {
      "source": "/__winga-image__",
      "destination": "https://winga-pflp.onrender.com/__winga-image__"
    },
    {
      "source": "/product/:id",
      "destination": "/api/product/:id"
    }
  ],
  "redirects": [
    {
      "source": "/winga",
      "destination": "/",
      "permanent": false
    }
  ]
}
