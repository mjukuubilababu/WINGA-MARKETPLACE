{
  "name": "winga-app",
  "private": true,
  "scripts": {
    "build:vercel": "node scripts/build-vercel-static.js",
    "verify:production": "node scripts/verify-production-shell.js",
    "verify:worker-performance": "node scripts/verify-worker-performance.js",
    "verify:domain-routing": "node scripts/verify-domain-routing.js",
    "verify:source": "node scripts/verify-source-of-truth.js",
    "test": "npm run test:frontend && npm run test:integration && npm run test:e2e",
    "test:frontend": "node tests/frontend-core.test.js",
    "test:integration": "node --test tests/integration-api.test.js tests/postgres-pagination.test.js",
    "test:e2e": "playwright test",
    "deploy:worker:frontend": "npm run build:vercel && npx wrangler deploy --config wrangler.toml",
    "deploy:worker:intelligence": "npx wrangler deploy --config wrangler.intelligence.toml",
    "deploy:worker:session-security": "npx wrangler deploy --config wrangler.session-security.toml",
    "deploy:worker:account-recovery": "npx wrangler deploy --config wrangler.account-recovery.toml",
    "verify:frontend-worker-routing": "node scripts/verify-domain-routing.js --runtime=worker",
    "monitor:intelligence": "node scripts/check-intelligence-health.js",
    "ops:intelligence:list": "node scripts/intelligence-ops.js list",
    "ops:intelligence:retry": "node scripts/intelligence-ops.js retry",
    "ops:intelligence:dead": "node scripts/intelligence-ops.js dead",
    "worker:intelligence": "node backend/intelligence-queue-worker.js",
    "worker:intelligence:once": "node backend/intelligence-queue-worker.js --once",
    "verify:feed-production": "node scripts/verify-feed-production.js",
    "test:feed-production": "node tests/frontend-core.test.js && node --test tests/postgres-pagination.test.js && playwright test tests/e2e/pagination-bootstrap.spec.js tests/e2e/cls-hardening.spec.js --reporter=list && playwright test tests/e2e/app.spec.js --grep \"gallery|swipe|edge to edge|installed PWA|browser back from the first product|refreshing a product deep link|logged in sellers can scroll|guest home renders|vertical page scroll\" --reporter=list"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
