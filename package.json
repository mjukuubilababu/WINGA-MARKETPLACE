{
  "name": "winga-app",
  "private": true,
  "scripts": {
    "build:vercel": "node scripts/build-vercel-static.js",
    "verify:production": "node scripts/verify-production-shell.js",
    "verify:domain-routing": "node scripts/verify-domain-routing.js",
    "test": "npm run test:frontend && npm run test:integration && npm run test:e2e",
    "test:frontend": "node tests/frontend-core.test.js",
    "test:integration": "node --test tests/integration-api.test.js tests/postgres-pagination.test.js",
    "test:e2e": "playwright test",
    "monitor:intelligence": "node scripts/check-intelligence-health.js",
    "worker:intelligence": "node backend/intelligence-queue-worker.js",
    "worker:intelligence:once": "node backend/intelligence-queue-worker.js --once"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
